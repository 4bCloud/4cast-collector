# Worker Settings
WORKER_MODE=false
WORKER_API_KEY=
API_BASE_URL=http://localhost:8000

# Durable Job Queue (Postgres - ADR-1)
DATABASE_URL=postgresql://user:pass@localhost:5432/4cast
# POSTGRES_JOBS_DATABASE_URL=...

# Real-time Progress (Redis - ADR-5)
REDIS_URL=redis://localhost:6379/0

# Object Storage (S3 / MinIO - ADR-4)
OBJECT_STORAGE_BUCKET=4cast-artifacts
# OBJECT_STORAGE_ENDPOINT=http://localhost:9000
# OBJECT_STORAGE_ACCESS_KEY=
# OBJECT_STORAGE_SECRET_KEY=

# Collection Tuning
MAX_CONCURRENT_ACCOUNTS=10
MAX_CONCURRENT_APIS_PER_ACCOUNT=8
